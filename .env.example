# 开发推荐 SQLite（路径相对项目根目录，与启动 cwd 无关）
DATABASE_URL=sqlite:///./agent_system.db

# 生产 PostgreSQL 示例（需 pip install psycopg2-binary）
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_system

# JWT
SECRET_KEY=change-this-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM（形成性评价 / AI 作业分析，DeepSeek 示例）
# 以下三组变量名任选其一即可，代码会自动识别：
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
# LLM_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
